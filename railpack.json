{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "22"
  },
  "steps": {
    "install": {
      "commands": [
        { "src": ".", "dest": "." },
        { "cmd": "npm --prefix backend ci", "customName": "Install backend deps" },
        { "cmd": "npm --prefix frontend ci", "customName": "Install frontend deps" }
      ]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "secrets": ["VITE_BACKEND_URL", "VITE_HOURS_CLOSE_TICKETS_AUTO", "VITE_MASTERADMIN"],
      "commands": [
        { "cmd": "npm --prefix backend run build", "customName": "Build backend" },
        { "cmd": "npm --prefix frontend run build", "customName": "Build frontend" },
        { "cmd": "npm --prefix backend install pm2 sequelize-cli --no-save", "customName": "Install PM2 + sequelize-cli (local)" },
        { "cmd": "sh -c 'mkdir -p .node-bin && cp \"$(node -p process.execPath)\" .node-bin/node && ./.node-bin/node -v'", "customName": "Stage node binary into app tree" }
      ]
    }
  },
  "deploy": {
    "aptPackages": [
      "chromium",
      "ffmpeg",
      "ca-certificates",
      "fonts-liberation"
    ],
    "variables": {
      "NODE_ENV": "production",
      "CHROME_BIN": "/usr/bin/chromium",
      "PUPPETEER_EXECUTABLE_PATH": "/usr/bin/chromium",
      "PATH": "/app/.node-bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
    },
    "startCommand": "(cd backend && /app/.node-bin/node node_modules/.bin/sequelize db:migrate) && /app/.node-bin/node backend/node_modules/.bin/pm2-runtime start ecosystem.config.js"
  }
}
